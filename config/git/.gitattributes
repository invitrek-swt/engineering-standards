* text=auto

# Always use LF for common text formats
*.md        text eol=lf
*.txt       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.xml       text eol=lf
*.props     text eol=lf
*.targets   text eol=lf
*.config    text eol=lf
*.editorconfig text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf

# Source code
*.cs        text eol=lf
*.csproj    text eol=lf
*.sln       text eol=crlf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
*.html      text eol=lf

# Scripts
*.ps1       text eol=crlf
*.cmd       text eol=crlf
*.bat       text eol=crlf
*.sh        text eol=lf

# Binaries
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.zip       binary
*.7z        binary
*.ttf       binary
*.otf       binary
*.woff      binary
*.woff2     binary

# Minified
*.min.js    -text
*.min.css   -text
